rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Check if user belongs to a tenant
    function isTenantMember(tenantId) {
      return isAuth() && exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid));
    }

    // Helper: Get user's role in a tenant
    function getUserRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role;
    }

    // Helper: Check if user is admin of tenant
    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) && getUserRole(tenantId) == 'admin';
    }

    // Helper: Check if user is admin or manager
    function isTenantManager(tenantId) {
      return isTenantMember(tenantId) && getUserRole(tenantId) in ['admin', 'manager'];
    }

    // Tenants collection
    match /tenants/{tenantId} {
      // Only members can read their tenant
      allow read: if isTenantMember(tenantId);
      // Only admins can update tenant settings
      allow update: if isTenantAdmin(tenantId);
      // Creation is handled by the server (API routes)
      allow create, delete: if false;

      // Users subcollection
      match /users/{userId} {
        // Members can read all users in their tenant
        allow read: if isTenantMember(tenantId);
        // Users can update their own profile
        allow update: if isAuth() && request.auth.uid == userId;
        // Admins can manage users
        allow create, delete: if isTenantAdmin(tenantId);
        // Admins can update any user (role changes)
        allow update: if isTenantAdmin(tenantId);
      }

      // Records subcollection
      match /records/{recordId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && getUserRole(tenantId) in ['admin', 'manager', 'employee'];
        allow update: if isTenantMember(tenantId) && getUserRole(tenantId) in ['admin', 'manager', 'employee'];
        allow delete: if isTenantManager(tenantId);
      }

      // Fields subcollection (custom fields config)
      match /fields/{fieldId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Documents subcollection
      match /documents/{docId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && getUserRole(tenantId) in ['admin', 'manager', 'employee'];
        allow delete: if isTenantManager(tenantId);
      }

      // Activity/audit log
      match /activity/{activityId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId);
        allow update, delete: if false;
      }
    }

    // Invites collection (top-level)
    match /invites/{inviteId} {
      // Anyone with the invite ID can read it (for the invite page)
      allow read: if true;
      // Creation and updates handled by server
      allow create, update, delete: if false;
    }

    // Mail collection (for Firebase Trigger Email extension)
    match /mail/{mailId} {
      // Only server can write
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
